# tmux configuration snippet for PomoGo integration.
# Add the following line to your ~/.tmux.conf to show the Pomodoro timer in the status bar:
#
# set -g status-right "#(pomogo status --format tmux) | %H:%M "
#
# If you want to customize the status-right refresh interval (default is 15s, but 1s is recommended for a live clock):
# set -g status-interval 1
